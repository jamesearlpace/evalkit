# Environment variables for eval-accelerator.
# Copy to `.env` and fill in. NEVER commit a real .env.

# --- OpenAI ---
OPENAI_API_KEY=

# --- Azure OpenAI (optional alternative provider) ---
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT=

# Default model used by the LLM-as-judge evaluators.
EVALACC_JUDGE_MODEL=gpt-4o-mini
